<?php
// LC-ADVANCE - Unit Test Framework
// Simple assertions - no external dependencies
class TestCase {
    private $passed = 0;
    private $failed = 0;
    private $name = '';
    public function __construct($name = '') { $this->name = $name; }
    public function assertEquals($expected, $actual, $msg = '') {
        if ($expected === $actual) { $this->passed++; return true; }
        $this->failed++;
        $loc = debug_backtrace(DEBUG_BACKTRACE_IGNORE_ARGS, 3)[2] ?? [];
        $file = basename($loc['file'] ?? '?');
        $line = $loc['line'] ?? '?';
        $m = $msg ?: "Expected '" . var_export($expected, true) . "' but got '" . var_export($actual, true) . "'";
        echo "  FAIL [$file:$line] $m\n";
        return false;
    }
    public function assertTrue($val, $msg = '') { return $this->assertEquals(true, $val, $msg ?: "Expected true"); }
    public function assertFalse($val, $msg = '') { return $this->assertEquals(false, $val, $msg ?: "Expected false"); }
    public function assertNull($val, $msg = '') { return $this->assertEquals(null, $val, $msg ?: "Expected null"); }
    public function assertNotNull($val, $msg = '') { return $this->assertNotEquals(null, $val, $msg ?: "Expected not null"); }
    public function assertNotEquals($expected, $actual, $msg = '') {
        if ($expected !== $actual) { $this->passed++; return true; }
        $this->failed++;
        echo "  FAIL {$msg} - values should differ\n";
        return false;
    }
    public function assertArrayHasKey($key, $arr, $msg = '') {
        if (is_array($arr) && array_key_exists($key, $arr)) { $this->passed++; return true; }
        $this->failed++;
        echo "  FAIL {$msg} - array does not have key\n";
        return false;
    }
    public function assertCount($expected, $arr, $msg = '') {
        $c = is_array($arr) ? count($arr) : (is_countable($arr) ? count($arr) : -1);
        if ($c === $expected) { $this->passed++; return true; }
        $this->failed++;
        echo "  FAIL {$msg} - expected count $expected, got $c\n";
        return false;
    }
    public function assertStringContains($needle, $haystack, $msg = '') {
        if (is_string($haystack) && strpos($haystack, $needle) !== false) { $this->passed++; return true; }
        $this->failed++;
        echo "  FAIL {$msg} - substring not found\n";
        return false;
    }
    public function assertInstanceOf($class, $obj, $msg = '') {
        if ($obj instanceof $class) { $this->passed++; return true; }
        $this->failed++;
        echo "  FAIL {$msg} - not instance of $class\n";
        return false;
    }
    public function summary() { return [$this->passed, $this->failed]; }
}
function runTests($name, TestCase $tc) {
    echo "=== $name ===\n";
    $tc->assertTrue(true, 'placeholder'); // keep tc alive
    list($p, $f) = $tc->summary();
    echo "  PASSED: $p | FAILED: $f\n";
    return $f === 0;
}
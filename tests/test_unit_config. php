function testQuizScoring() {
    $tc = new TestCase('Quiz Scoring');
    // Test scoring: score * 10 XP
    $score = 3;
    $xp = $score * 10;
    $tc->assertEquals(30, $xp);
    // Test strcasecmp matching (como en calificar_quiz)
    $correcta = '  La respuesta 1  ';
    $correct = 'la respuesta 1';
    $tc->assertEquals(0, strcasecmp(trim($correcta), $correct));
    $wrong = 'la respuesta 2';
    $tc->assertFalse(strcasecmp(trim($wrong), $correct) === 0);
    // Test loop scoring
    $preguntas = [
        ['pregunta' => 'Q1', 'correcta' => 'A'],
        ['pregunta' => 'Q2', 'correcta' => 'B'],
        ['pregunta' => 'Q3', 'correcta' => 'C'],
    ];
    $respuestas = ['A', 'B', 'X']; // 2 correct
    $calc_score = 0;
    foreach ($preguntas as $i => $p) {
        if (strcasecmp(trim($respuestas[$i]), trim($p['correcta'])) === 0) $calc_score++;
    }
    $tc->assertEquals(2, $calc_score);
    $tc->assertEquals(20, $calc_score * 10);
    list($p, $f) = $tc->summary();
    echo "  PASSED: $p | FAILED: $f\n";
    return $f === 0;
}

function testRateLimitLogic() {
    $tc = new TestCase('Rate Limit Logic');
    // 5 failed logins = lockout
    $attempts = 0;
    for ($i = 1; $i <= 5; $i++) $attempts++;
    $tc->assertEquals(5, $attempts);
    $blocked = ($attempts >= 5);
    $tc->assertTrue($blocked);
    // 30 API/requests/min
    $api_count = 0;
    for ($i = 1; $i <= 30; $i++) $api_count++;
    $tc->assertEquals(30, $api_count);
    $api_limited = ($api_count > 30);
    $tc->assertFalse($api_limited);
    $api_limited2 = (31 > 30);
    $tc->assertTrue($api_limited2);
    list($p, $f) = $tc->summary();
    echo "  PASSED: $p | FAILED: $f\n";
    return $f === 0;
}


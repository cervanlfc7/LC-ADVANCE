<?php
// Simple test assertions (no external deps)
class TC {
    private $p = 0, $f = 0;
    function eq($e, $a, $m = '') { if ($e === $a) { $this->p++; return true; } $this->f++; echo "  FAIL $m\n"; return false; }
    function t($v, $m = '') { return $this->eq(true, $v, $m); }
    function f($v, $m = '') { return $this->eq(false, $v, $m); }
    function n($v, $m = '') { return $this->eq(null, $v, $m); }
    function nn($v, $m = '') { if ($v !== null) { $this->p++; return true; } $this->f++; echo "  FAIL $m\n"; return false; }
    function c($e, $a, $m = '') { $c = is_array($a) ? count($a) : -1; if ($c === $e) { $this->p++; return true; } $this->f++; echo "  FAIL $m\n"; return false; }
    function s() { return [$this->p, $this->f]; }
}